########################################################################
package Bedrock::MiniServer; ## no critic
########################################################################

use strict;
use warnings;

# make sure Bedrock is first to fix @INC
use Bedrock qw(slurp_file is_hash is_array to_boolean benchmark choose $BEDROCK_DIST_DIR);

use Apache::Request::CGI;
use Bedrock::Constants qw(:chars %LOG4PERL_LOG_LEVELS :booleans :http);
use Bedrock::BedrockConfig;
use Bedrock::Error qw(handle_error resolve_error_page);
use Bedrock::MiniServer::Context;
use Bedrock::Router;
use Benchmark;
use Data::Dumper;
use Carp;
use Cwd qw(cwd getcwd);
use English qw(-no_match_vars);
use File::Basename;
use IO::Scalar;
use JSON::Schema::Validate;
use List::Util qw(pairs);
use Log::Log4perl;
use POSIX qw(strftime);
use Module::Load;
use Scalar::Util qw(blessed reftype);
use Text::URLEncode qw(Htmlencode);
use YAML::XS;

use Role::Tiny::With;
with 'Bedrock::Logger';

our $version = '@PACKAGE_VERSION@';

use parent qw(HTTP::Server::Simple::CGI);

{
  no warnings 'once'; ## no critic
  $Log::Log4perl::Config::ALLOW_CODE = 1;  # allow us to use cspec for Log::Log4perl
}

########################################################################
sub new {
########################################################################
  my ( $class, $port, $family, %args ) = @_;

  my $bedrock_runtime = delete $args{bedrock_runtime} // {};

  my $self = $class->SUPER::new( $port, $family, %args );

  $self->{_bedrock_runtime} = $bedrock_runtime;

  return $self;
}

########################################################################
sub bedrock_server_config {
########################################################################
  my ( $self, $config ) = @_;

  if ($config) {
    $self->{_bedrock_runtime} = $config;
  }

  return $self->{_bedrock_runtime} // {};
}

########################################################################
sub handle_request {
########################################################################
  my ( $self, $cgi ) = @_;

  my $t0 = benchmark();

  # init logging for miniserver...
  my $logger = $self->_init_miniserver_logger( $self->bedrock_server_config->{log_level} );

  my $env = $self->bedrock_server_config->{env} // {};

  local @ENV{ keys %{$env} } = values %{$env};

  if ( my ( $mount, $service ) = $self->_exact_service_match($cgi) ) {
    my $ret_val = $self->_service( $cgi, $service, $mount );
    $self->_log_complete(
      path         => $cgi->path_info,
      request_time => benchmark($t0)->[0],
      cgi          => $cgi,
      logger       => $logger,
    );
    return $ret_val;
  }
  else {
    $logger->debug( 'no exact service match for ', $cgi->path_info );
  }

  # Check directory index before alias resolution
  if ( $self->_resolve_directory_index($cgi) ) {
    $self->_log_complete(
      path         => $cgi->path_info,
      request_time => benchmark($t0)->[0],
      cgi          => $cgi,
      logger       => $logger,
    );

    return;
  }

  # check to see if request is for static or template asset
  if ( $self->_serve_alias($cgi) ) {
    $self->_log_complete(
      path         => $cgi->path_info,
      request_time => benchmark($t0)->[0],
      cgi          => $cgi,
      logger       => $logger,
    );

    return;
  }

  my ( $template, $route_params, $path_translated ) = $self->_resolve_template_route($cgi);

  if ($template) {
    # Resolve against PEBBLE_DIR like Apache::Bedrock
    my $pebble_dir = $self->bedrock_server_config->{PEBBLE_DIR} // $ENV{SERVER_ROOT} // Cwd::getcwd();

    my $fs_path = "$pebble_dir/$template";

    $logger->debug( sprintf 'Route matched! Checking filesystem for: [%s]', $fs_path );
    $logger->debug( sprintf 'Current Working Directory: %s',                Cwd::getcwd() );

    if ( -r $fs_path ) {
      $logger->debug('File found and readable. Invoking _serve_template.');
      $self->_serve_template( $cgi, $fs_path, $route_params, $path_translated );

      return $self->_log_complete(
        path         => $cgi->path_info,
        request_time => benchmark($t0)->[0],
        cgi          => $cgi,
        logger       => $logger
      );
    }
    else {
      $logger->error( sprintf 'ROUTING FAILURE: Match found (%s) but file not readable at [%s]', $template, $fs_path );
    }
  }

  # see if the request is handled by a service
  my ( $mount, $service ) = $self->_is_service($cgi);

  return $self->_not_found()
    if !$service;

  my $path_info = $self->_service( $cgi, $service, $mount );

  $self->_log_complete(
    cgi          => $cgi,
    request_time => benchmark($t0)->[0],
    path         => $cgi->path_info,
    path_info    => $path_info,  # the possibly remapped path
    logger       => $logger,
  );

  return;
}

########################################################################
sub _exact_service_match {
########################################################################
  my ( $self, $cgi ) = @_;

  my $path = $cgi->path_info;

  my $services = $self->bedrock_server_config->{service_registry} // {};

  # Check exact match (with or without trailing slash)
  foreach my $mount ( keys %{$services} ) {
    $self->get_logger->debug( sprintf 'checking service mount %s <=> %s', $mount, $path );

    return ( $mount, $services->{$mount} )
      if $path eq $mount || $path eq "$mount/";
  }

  return;
}

########################################################################
sub _resolve_template_route {
########################################################################
  my ( $self, $cgi ) = @_;

  my $logger = Log::Log4perl->get_logger( ref $self );

  require Bedrock::Router;

  my $routes_config = $self->bedrock_server_config->{routes}  || {};
  my $aliases       = $self->bedrock_server_config->{aliases} || {};

  foreach my $mount ( keys %{$routes_config} ) {
    next if index( $cgi->path_info, $mount ) != 0;

    my $rel_path = substr $cgi->path_info, length $mount;

    if ( $rel_path !~ m{^/}xsm ) {
      $rel_path = "/$rel_path";
    }

    # DIAGNOSTIC: Check structure before passing to Router
    my $rules = $routes_config->{$mount};

    # If rules is a HASH, we must convert it to an ARRAY for Bedrock::Router
    if ( ref($rules) eq 'HASH' ) {
      $logger->debug( sprintf 'Converting HASH routes to ARRAY for mount: %s', $mount );
      $rules = [ map { { pattern => $_, template => $rules->{$_} } } keys %{$rules} ];
    }

    $logger->debug( sprintf 'Attempting route match: Mount[%s] Path[%s]', $mount, $rel_path );

    my $router = Bedrock::Router->new( { routes => $rules } );
    if ( my $match = $router->match($rel_path) ) {
      $logger->info( sprintf 'Route Match Found! Template: %s', $match->{template} );
      # NEW: Resolve PATH_TRANSLATED from route params
      my $path_translated = $self->_resolve_path_translated( $match->{params}, $aliases, $logger );

      return ( $match->{template}, $match->{params}, $path_translated );
    }
  }

  $logger->debug( sprintf 'No route matched for: %s', $cgi->path_info );

  return;
}

########################################################################
sub _resolve_path_translated {
########################################################################
  my ( $self, $route_params, $aliases, $logger ) = @_;

  # Extract the captured path from route params (e.g., 'path' from /markdown/*path)
  my $captured_path = $route_params->{path} || return;

  $logger->debug( sprintf 'Resolving PATH_TRANSLATED for captured path: %s', $captured_path );

  # Find which alias this path belongs to by checking prefixes
  foreach my $alias_prefix ( _sort_by_longest($aliases) ) {
    next if index( "/$captured_path", $alias_prefix ) != 0;

    my $alias_base = $aliases->{$alias_prefix};

    # Strip the alias prefix and append to the filesystem base
    my $rel_part = substr "/$captured_path", length $alias_prefix;
    my $fs_path  = $alias_base . $rel_part;

    # Convert to absolute path if it's relative
    if ( $fs_path !~ m{^/}xsm ) {
      require File::Spec;
      require Cwd;
      $fs_path = File::Spec->rel2abs( $fs_path, Cwd::getcwd() );
    }

    $logger->debug( sprintf 'PATH_TRANSLATED resolved: %s -> %s', $captured_path, $fs_path );
    return $fs_path;
  }

  return;
}

########################################################################
sub _service {
########################################################################
  my ( $self, $cgi, $service, $mount ) = @_;

  my $logger = Log::Log4perl->get_logger( ref $self );

  my $path_info = $self->_service_route( $cgi, $mount );

  # Virtualize the Environment for the Service
  local $ENV{SCRIPT_NAME} = $mount eq $SLASH ? $EMPTY : $mount;
  local $ENV{PATH_INFO}   = $path_info;

  $service->request(undef);
  $service->context(undef);
  $service->bedrock_handler(undef);

  my $r = Apache::Request::CGI->new();

  eval { $service->handler($r); };

  my $err = $EVAL_ERROR;

  if ( my $session = $service->session ) {
    if ( $session->can('closeBLM') ) {
      $session->closeBLM;
      $service->set( session => undef );  # so DESTROY does not try to closeBLM either
    }
  }

  if ($err) {
    handle_error( $r, $err );
    $logger->error( sprintf 'CRITICAL ERROR in %s: %s', $mount, $err );
  }

  return $path_info;
}

########################################################################
sub _service_route {
########################################################################
  my ( $self, $cgi, $mount ) = @_;

  # Calculates the "Service-Relative Path" (PATH_INFO).
  #
  # This logic enables "Virtual Mounting" by isolating the Service from
  # its public URL prefix. It prioritizes:
  # 1. Regex Rewrites: Checks the 'routes' config for complex mappings.
  # 2. Prefix Stripping: If mounted at '/api', a request to '/api/users'
  #    is translated to '/users' so the Service handles it correctly.
  # 3. Normalization: Ensures the path is never empty (defaults to '/').

  my $path_info = $self->_xlate_path( $mount, $cgi );

  if ( !$path_info && $mount ne $SLASH ) {
    $path_info = substr $cgi->path_info, length $mount;
  }

  $path_info ||= $SLASH;

  return $path_info;
}

########################################################################
sub _xlate_path {
########################################################################
  my ( $self, $mount, $cgi ) = @_;

  my $routes = $self->bedrock_server_config->{routes} || {};

  my $rules = $routes->{$mount};

  return
    if !$rules;

  # Route Translation / Rewriting
  my $path_info;

  my $path = $cgi->path_info;

  foreach my $pattern ( _sort_by_longest($rules) ) {
    my $regex = $pattern;
    my @vars;

    while ( $regex =~ m{(:[[:alnum:]_]+)}xsm ) {
      push @vars, $1;
      $regex =~ s/$1/([^\/]+)/xsm;
    }

    if ( my @captures = $path =~ m{\A$regex\z}xsm ) {
      my $target = $rules->{$pattern};

      for my $i ( 0 .. $#vars ) {
        my $token = $vars[$i];
        my $val   = $captures[$i];

        $target =~ s/$token/$val/xsm;
      }

      $path_info = $target;
      last;
    }
  }

  return $path_info;
}

########################################################################
sub _is_service {
########################################################################
  my ( $self, $cgi ) = @_;

  my $registry = $self->bedrock_server_config->{service_registry} || {};

  my $path = $cgi->path_info();

  foreach my $m ( _sort_by_longest($registry) ) {
    next if index( $path, $m ) != 0;

    return ( $m, $registry->{ $m // q{} } );
  }

  return;
}

########################################################################
sub _resolve_directory_index {
########################################################################
  my ( $self, $cgi ) = @_;

  my $logger        = $self->get_logger;
  my $server_config = $self->bedrock_server_config;
  my $dir_index     = $server_config->{directory_index} // {};
  my $aliases       = $server_config->{aliases}         // {};
  my $path          = $cgi->path_info;

  # Find the longest matching directory_index prefix for this request
  foreach my $dir ( reverse sort { length($a) <=> length($b) } keys %{$dir_index} ) {
    # Normalize: /foo, /foo/, and /foo/index.roc all match /foo
    my $norm_dir = $dir;
    $norm_dir =~ s{/\z}{}xsm;

    next if $path ne $norm_dir && $path ne "$norm_dir/";

    my $candidates = $dir_index->{$dir};
    $candidates = [$candidates] if !is_array($candidates);

    # Resolve the filesystem base for this directory via aliases
    my $base = $EMPTY;
    foreach my $alias ( reverse sort { length($a) <=> length($b) } keys %{$aliases} ) {
      my $norm_alias = $alias;
      $norm_alias =~ s{/\z}{}xsm;
      next if $norm_dir ne $norm_alias && index( "$norm_dir/", "$norm_alias/" ) != 0;
      $base = $aliases->{$alias};
      last;
    }

    # Try each candidate in order, serve the first readable one
    foreach my $f ( @{$candidates} ) {
      my $fs_path = "${base}${f}";

      $logger->debug( sprintf 'directory_index: trying [%s]', $fs_path );

      if ( -r $fs_path ) {
        $logger->info( sprintf 'directory_index: serving [%s] for [%s]', $fs_path, $path );
        return $self->_serve_static( $cgi, $path, $fs_path );
      }
    }

    $logger->debug( sprintf 'directory_index: no candidate found for [%s]', $path );
    return;  # matched the dir but nothing readable — stop looking
  }

  return;
}

########################################################################
sub _serve_alias {
########################################################################
  my ( $self, $cgi ) = @_;

  my $aliases = $self->bedrock_server_config->{aliases} // {};

  my $path = $cgi->path_info;

  foreach my $alias ( _sort_by_longest($aliases) ) {
    next if index( $path, $alias ) != 0;

    return $self->_serve_static( $cgi, $alias, $aliases->{$alias} );
  }

  return;
}

########################################################################
sub _init_miniserver_logger {
########################################################################
  my ( $self, $log_level ) = @_;

  my $logger = get_logger( ref $self );

  $log_level //= 'info';
  $logger->level( $LOG4PERL_LOG_LEVELS{$log_level} // $LOG4PERL_LOG_LEVELS{info} );

  return $logger;
}

########################################################################
sub _log_complete {
########################################################################
  my ( $self, %args ) = @_;

  $args{path_info} //= q{};

  foreach (qw(request_method user_agent referer)) {
    $args{$_} = $args{cgi}->$_ // q{};
  }

  $args{logger}->notice( sprintf '%s %s (%s) %s %s', @args{qw(request_method path request_time referer user_agent)} );

  return;
}

########################################################################
sub _not_found {
########################################################################
  my ($self) = @_;

  my $error_docs = $self->bedrock_server_config->{error_document} // {};
  my $aliases    = $self->bedrock_server_config->{aliases}        // {};

  my $error_page = $error_docs->{404};

  my $not_found_page = choose {
    return "$BEDROCK_DIST_DIR/htdocs/not-found.html"
      if !$error_page;

    # could be set as an absolute path
    return $error_page
      if -r $error_page;

    # or an alias
    foreach my $alias ( _sort_by_longest($aliases) ) {
      next if index( $error_page, $alias ) != 0;

      my $err_fs = $aliases->{$alias} . substr $error_page, length $alias;
      return $err_fs;
    }

    return;
  };

  my $content = -r $not_found_page ? slurp_file($not_found_page) : 'File not found';

  print "HTTP/1.0 404 Not Found\r\nContent-Type: text/html\r\n";
  print "Connection: close\r\n\r\n";
  print $content;

  return;
}

########################################################################
sub _sort_by_longest {
########################################################################
  my ($hash) = @_;

  return reverse sort { length($a) <=> length $b } keys %{$hash};
}

########################################################################
sub _serve_template {
########################################################################
  my ( $self, $cgi, $fs_path, $route_params, $path_translated ) = @_;

  # This simply re-uses the logic from _serve_static but bypasses
  # the alias/filesystem existence checks because we've already
  # resolved the path.

  # We call _serve_static but pass the full file path as the local_base
  # to force it to treat the file as the target.
  return $self->_serve_static( $cgi, $cgi->path_info, $fs_path, $route_params, $path_translated );
}

########################################################################
sub _serve_static {
########################################################################
  my ( $self, $cgi, $alias_url, $local_base, $route_params, $path_translated ) = @_;

  my $logger = Log::Log4perl->get_logger( ref $self );

  my $path = $cgi->path_info();

  # Calculate relative path
  my $rel_file = substr $path, length $alias_url;

  # 1. Security Check: Block directory traversal
  if ( $rel_file =~ /[.]{2}/xsm ) {
    print "HTTP/1.0 403 Forbidden\r\nConnection: close\r\n\r\n";
    return $TRUE;
  }

  # 2. Shadowing Detection
  # If alias maps to a FILE, but request implies it's a directory, decline.
  my $is_file_alias = ( -e $local_base && !-d $local_base )
    || ( !-e $local_base && $local_base =~ m{[.][[:alnum:]]+$}xsm );

  if ( $is_file_alias && length($rel_file) > 0 && $rel_file ne $SLASH ) {
    $logger->debug("serve_static: Shadowing detected for $path. Declining.");
    return $FALSE;
  }

  # Inside _serve_static
  my $fs_path = $local_base;
  if ( length $rel_file && $rel_file ne $SLASH ) {
    $fs_path .= $rel_file;
  }

  # Add this log to catch the 404 source
  if ( !-e $fs_path || !-r $fs_path ) {
    $logger->error("File system check failed for: $fs_path");
    return $FALSE;
  }

  if ( -d $fs_path ) {
    $logger->debug("Path is a directory, declining: $fs_path");
    return $FALSE;  # Let it fall through to services
  }

  # --- If we get here, we are definitely serving this file ---
  my ($ext) = $fs_path =~ /[.]([^.]+)$/xsm;
  $ext = lc( $ext || $EMPTY );

  my $server_config = $self->bedrock_server_config;

  my $type = $server_config->{mime_types}->{$ext} || 'text/plain';

  my $global_config = $server_config->{global_config} || {};

  if ( !$server_config->{parse_templates} || !$server_config->{template_extensions}->{$ext} ) {
    _serve_static_content( $fs_path, $type, $server_config->{no_cache} );
    return $TRUE;
  }

  my $tpl;

  # Create capture buffer and IO handle
  my $headers_out = $EMPTY;
  my $io          = IO::Scalar->new( \$headers_out );

  my $tagx_config = $server_config->{bedrock_config};

  eval {
    # We only need to override the path info to trick the template
    # into thinking it is running inside the alias.
    # Everything else (Method, Query String, Extra Env) is already in global %ENV.

    local $ENV{SCRIPT_NAME}     = $alias_url eq $SLASH ? $EMPTY : $alias_url;
    local $ENV{PATH_INFO}       = $rel_file;
    local $ENV{SCRIPT_FILENAME} = $path_translated if $path_translated;  # Apache standard
    local $ENV{PATH_TRANSLATED} = $path_translated if $path_translated;  # CGI fallback
      # ------------------------------------------------------

    require Bedrock::Template;
    require BLM::Startup::Header;
    require BLM::Startup::Input;
    require BLM::Startup::Env;
    require BLM::Startup::Bedrock;
    require BLM::Startup::Config;

    my $ctx = Bedrock::MiniServer::Context->new(
      $io,
      cgi          => $cgi,
      config       => $tagx_config,
      route_params => $route_params || {},
    );

    my $input   = BLM::Startup::Input->new( $ctx, $tagx_config->get_module_config('Input')     || {} );
    my $header  = BLM::Startup::Header->new( $ctx, $tagx_config->get_module_config('Header')   || {} );
    my $bedrock = BLM::Startup::Bedrock->new( $ctx, $tagx_config->get_module_config('Bedrock') || {} );
    my $env     = BLM::Startup::Env->new;

    my $session = _init_session( $ctx, $global_config );

    my $cwd = getcwd();

    my $content = slurp_file($fs_path);
    my ( undef, $path ) = fileparse( $fs_path, qr/[.][^.]+$/xsm );

    chdir $path;

    $header->content_type($type);

    my $server_config_lite = Bedrock::Hash->new(
      map  { $_ => $server_config->{$_} }
      grep { exists $server_config->{$_} }
        qw(aliases routes env log_level parse_templates
        template_extensions mime_types error_document
        directory_index port services session)
    );

    $tpl = Bedrock::Template->new(
      $content,
      header        => $header,
      input         => $input,
      session       => $session,
      config        => bless( $tagx_config, 'BLM::Startup::Config' ),
      env           => $env,
      bedrock       => $bedrock,
      server_config => $server_config_lite,
    );

    $tpl->set_source($fs_path);

    my $output = eval {
      # Execute parsing first (populates $buffer via $ctx)
      return $tpl->parse();
    };

    my $err = $EVAL_ERROR;

    chdir $cwd;

    die $err
      if $err;

    # ...better do these now, while $header still has its headers...
    my $status_text = $header->get_status_line();
    my $is_redirect = $header->is_redirect;

    # BLMs must be explicitly closed
    foreach my $plugin ( $header, $input, $session, $env, $bedrock ) {
      next if !$plugin || !$plugin->can('closeBLM');

      $plugin->closeBLM;
    }

    # 1. Get the status line from the Header plugin logic
    # Returns "200 OK", "302 Found", etc.

    # 2. Delegate header printing...and there go the headers!
    $header->print_header($ctx);
    $io->close;

    print "HTTP/1.0 $status_text\r\n";
    print "Connection: close\r\n";

    if ( my $h_obj = $ctx->headers_out ) {
      foreach my $key ( sort keys %{$h_obj} ) {
        my $val    = $h_obj->{$key};
        my @values = is_array($val) ? @{$val} : ($val);

        foreach my $v (@values) {
          print "$key: $v\r\n";
        }
      }
    }

    print "\r\n";

    # 3. Only print body if NOT a redirect
    if ( !$is_redirect ) {
      print $output;
    }
  };

  my $err = $EVAL_ERROR;

  return $TRUE
    if !$err;

  $logger->error( Dumper( [ err => $err ] ) );

  $ENV{BEDROCK_ERROR_LOCATION} = resolve_error_page($tagx_config); ## no critic

  require Apache::Request::CGI;

  my $r = Apache::Request::CGI->new();

  my $buffer = $EMPTY;
  $tpl->set_output_handler( IO::Scalar->new( \$buffer ) );

  ######################################################################
  # Note: handle_error() usually requires a Text::TagX instance, but
  # actually only needs a 'show_error()' method. Bedrock::Template
  # instantiates a Text::TagX instances, stores it and provides a
  # show_error() method itself that delegates to the Text::TagX
  # instance...so yes this works.
  ######################################################################
  handle_error( $r, $err, $tpl );

  my $err_msg = "$err";

  if ( blessed($err) ) {
    if    ( $err->can('as_string') ) { $err_msg = $err->as_string; }
    elsif ( $err->can('mesg') )      { $err_msg = $err->mesg; }
    elsif ( $err->can('to_string') ) { $err_msg = $err->to_string; }
    else                             { $err_msg = Dumper($err); }
  }

  $logger->error("Template Parsing Failed for $fs_path: $err_msg");

  $buffer ||= $err_msg;

  print "HTTP/1.0 500 Internal Server Error\r\n";
  print "Content-Type: text/html\r\n";
  print "Connection: close\r\n\r\n";
  print $buffer;

  return $TRUE;

}

########################################################################
sub _serve_static_content {
########################################################################
  my ( $path, $content_type, $no_cache ) = @_;

  print "HTTP/1.0 200 OK\r\n";
  print "Content-Type: $content_type\r\n";
  print "Connection: close\r\n";

  if ( !to_boolean($no_cache) ) {
    my $last_modified = ( stat $path )[9];
    my $http_date     = strftime( '%a, %d %b %Y %H:%M:%S GMT', gmtime $last_modified );

    print "Last-Modified: $http_date\r\n";
    print "Cache-Control: max-age=86400, public\r\n";
  }

  print "\r\n";

  print scalar slurp_file($path);

  return $TRUE;
}

########################################################################
sub _init_session {
########################################################################
  my ( $ctx, $config ) = @_;

  my $session_config = $config->{session};

  return
    if !$session_config;

  my $class = $session_config->{module};

  load $class;

  my $session = $class->new( $ctx, $session_config->{config} // {} );

  return $session;
}

########################################################################
sub _render_template_error {
########################################################################
  my ( $err, $file_path ) = @_;

  my $msg = "$err";

  my $line;

  # Inspect Exception Object
  if ( blessed($err) ) {
    # 1. Try standard 'line' method
    if ( $err->can('line') ) {
      $line = $err->line;
    }
    # 2. Try TagX array-ref structure
    elsif ( is_array($err) && @{$err} && is_hash( $err->[0] ) ) {
      $line = $err->[0]->{line};
    }

    # 3. Extract Message
    if ( $err->can('as_string') ) {
      $msg = $err->as_string;
    }
    elsif ( is_array($err) && @{$err} && is_hash( $err->[0] ) ) {
      $msg = $err->[0]->{text} || "$err";
    }
  }
  # Fallback: Parse string for line number
  elsif ( $msg =~ /line\s+(\d+)/ixsm ) {
    $line = $1;
  }

  $msg = Htmlencode($msg);

  my $source = eval { slurp_file($file_path) } // $EMPTY;

  my @lines = split /\n/, $source;

  my $listing = $EMPTY;

  for my $i ( 0 .. $#lines ) {
    my $class = $line && $i == $line - 1 ? 'error' : 'code';
    $listing .= sprintf qq{<span class="%s"'>%4d: %s</span>\n}, $class, $i + 1, Htmlencode( $lines[$i] );
  }

  my $html = <<"END_OF_HTML";
<html>
  <head>
    <title>Template Error</title>
  </head>
  <body>
    <style>
    .error {
       background-color: #ffcccc;
       display: block;
       width: 100%;
     }

    .code {
      display: block:
      width: 100%;     
     }
    </style>

    <h1 style='color:red'>Template Error</h1>
    <pre><strong>$msg</strong></pre>
    <div style='border:1px solid #ccc; background:#f9f9f9; padding:10px; overflow:auto'>
      <pre>$listing</pre>
    </div>
  </body>
</html>
END_OF_HTML

  return $html;
}

########################################################################
package Bedrock::MiniServer::CLI; ## no critic
########################################################################
use Bedrock qw(choose slurp_json slurp_file $BEDROCK_DIST_DIR to_boolean is_hash is_array);
use Bedrock::Constants qw(%LOG4PERL_LOG_LEVELS);
use Bedrock::LoadConfig qw(load_config);
use Bedrock::XML qw(writeXML);
use CLI::Simple::Constants qw(:booleans :chars);
use Carp;
use Cwd;
use Data::Dumper;
use English qw(-no_match_vars);
use File::Path qw(make_path);
use Module::Load;
use List::Util qw(pairs);
use YAML::XS qw(DumpFile);

our $VERSION = '@PACKAGE_VERSION@';

use parent qw(CLI::Simple);

__PACKAGE__->use_log4perl;

########################################################################
sub main {
########################################################################
  my ( $class, $defaults ) = @_;

  my @option_specs = qw(
    config|c=s
    help|h
    log-level|l=s
    mount-point|m=s
    port|p=s
    service|s=s
    strict!
  );

  my @extra_options = qw(
    aliases
    dist_dir
    mime_types
    server_config
  );

  my $default_options = {
    mime_types => $defaults->{mime_types},
    aliases    => $defaults->{aliases},
    strict     => $TRUE,
  };

  my %commands = (
    default => \&cmd_start_server,
    start   => \&cmd_start_server,
  );

  my $cli = Bedrock::MiniServer::CLI->new(
    option_specs    => \@option_specs,
    extra_options   => \@extra_options,
    default_options => $default_options,
    commands        => \%commands,
  );

  return $cli->run();
}

########################################################################
sub cmd_start_server {
########################################################################
  my ($self) = @_;

  my $server_config = $self->get_server_config;

  # Set log level EARLY for startup messages
  my $log_level = $server_config->{log_level} || 'info';
  my $logger    = Log::Log4perl->get_logger('Bedrock::MiniServer');
  $logger->level( $LOG4PERL_LOG_LEVELS{$log_level} // $LOG4PERL_LOG_LEVELS{info} );

  # Capture the 'sovereign' launch root
  my $server_root = Cwd::getcwd();
  local $ENV{SERVER_ROOT} = $server_root;

  # Ensure PEBBLE_DIR defaults to this root if set to '.' or undefined
  if ( ( $server_config->{PEBBLE_DIR} // $EMPTY ) eq $DOT || !$server_config->{PEBBLE_DIR} ) {
    $server_config->{PEBBLE_DIR} = $server_root;
  }

  # ================================================================
  # Load the fully merged Bedrock config (tagx.xml + config.d/*)
  # ================================================================

  $ENV{BEDROCK_CONFIG_PATH} //= $server_config->{env}->{BEDROCK_CONFIG_PATH} // sprintf '%s/config', $BEDROCK_DIST_DIR;

  my $bedrock_config = eval {
    require Bedrock::FauxHandler;
    require Bedrock::Handler;

    my $faux_handler = Bedrock::FauxHandler->new(
      log       => $logger,
      log_level => $log_level,
    );

    return Bedrock::Handler->new($faux_handler)->config;
  };

  if ( !$bedrock_config || $EVAL_ERROR ) {
    $logger->warn( sprintf 'Could not load Bedrock config: %s', $EVAL_ERROR // 'unknown error' );
    $logger->warn('Falling back to minimal configuration');

    $bedrock_config = eval { return Bedrock::Config->new('tagx.xml'); } // {};
  }

  # Apply miniserver overrides to the bedrock config once
  if ( $server_config->{overrides} && is_hash( $server_config->{overrides} ) ) {
    foreach my $k ( keys %{ $server_config->{overrides} } ) {
      my $v = $server_config->{overrides}->{$k};
      $v =~ s/[@]dist_dir[@]/$BEDROCK_DIST_DIR/xsmg;
      $bedrock_config->{$k} = $v;
    }
  }

  # --- initialize runtime configuration
  my %runtime_config = (
    global_config    => $server_config,
    bedrock_config   => $bedrock_config,
    aliases          => $self->get_aliases,
    mime_types       => $self->get_mime_types,
    error_document   => {},
    service_registry => {},
    routes           => {},
    env              => {},
    log_level        => $server_config->{log_level} || 'info',
  );

  $server_config->{env} //= {};

  foreach my $k ( keys %{ $server_config->{env} } ) {
    $ENV{$k} = $server_config->{env}->{$k}; ## no critic
    $runtime_config{env}->{$k} = $server_config->{env}->{$k};
  }

  $runtime_config{error_document}  = $server_config->{error_document} || {};
  $runtime_config{parse_templates} = $server_config->{parse_templates};
  $runtime_config{directory_index} = $server_config->{directory_index} || {};

  # default template extensions
  $runtime_config{template_extensions} = { map { $_ => 1 } qw(roc rock jroc jrock) };

  if ( is_array( $server_config->{template_extensions} ) ) {
    $runtime_config{template_extensions} = { map { $_ => 1 } @{ $server_config->{template_extensions} } };
  }

  $runtime_config{mime_types} = { %{ $self->get_mime_types }, %{ $server_config->{mime_types} // {} } };

  my $global_service_config = $server_config->{service_config} // {};

  if ( $server_config->{session} ) {
    $global_service_config->{session} = $server_config->{session};
  }

  if ( $server_config->{overrides} ) {
    $global_service_config->{overrides} = $server_config->{overrides};
  }

  _resolve_paths($global_service_config);  # in case any values here are paths with [@]dist_dir[@]

  # ================================================================
  # Merge routes: Bedrock config routes as baseline, miniserver
  # YAML routes override. Bedrock config routes (from routes.xml)
  # are a flat array — they apply to the root mount point.
  # ================================================================
  my %merged_routes;

  if ( is_array( $bedrock_config->{routes} ) ) {
    $merged_routes{$SLASH} = $bedrock_config->{routes};
    $logger->info( sprintf 'Loaded %d route(s) from Bedrock config', scalar @{ $bedrock_config->{routes} } );
  }

  # miniserver YAML routes overlay (same keys win)
  my $yaml_routes = $server_config->{routes} || {};

  foreach my $mount ( keys %{$yaml_routes} ) {
    $merged_routes{$mount} = $yaml_routes->{$mount};
  }

  $runtime_config{routes} = \%merged_routes;

  my ( $services_cfg, $aliases_cfg ) = @{$server_config}{qw(services aliases)};

  $services_cfg //= {};

  my $mount_point = $self->get_mount_point // $server_config->{mount_point} // $SLASH;
  if ( my $service = $self->get_service ) {
    $services_cfg->{$mount_point} = $self->get_service;
  }

  carp q{WARNING: No services defined! Use --service or add a 'services' block to your config.}
    if !keys %{$services_cfg};

  foreach my $mount ( keys %{$services_cfg} ) {
    my $class = $services_cfg->{$mount};
    $self->_mount_service( \%runtime_config, $mount, $class, $global_service_config );
  }

  my $final_registry = {
    map { $_ => ref $runtime_config{service_registry}->{$_} }
      keys %{ $runtime_config{service_registry} }
  };

  foreach my $instance ( values %{ $runtime_config{service_registry} } ) {
    $instance->registry($final_registry);
  }

  $runtime_config{aliases} = { %{ $runtime_config{aliases} }, %{ $aliases_cfg // {} } };
  _resolve_paths( $runtime_config{aliases} );

  my $port        = $self->get_port // $server_config->{port} // 8080;
  my $line_length = 80;

  $logger->notice( q{=} x $line_length );
  $logger->notice( sprintf 'BEDROCK MINISERVER RUNNING ON PORT: %s', $port );

  $logger->notice( q{-} x $line_length );
  $logger->notice( sprintf 'BEDROCK_CONFIG_PATH: %s', $ENV{BEDROCK_CONFIG_PATH} // '(not set)' );

  $logger->notice( q{-} x $line_length );
  $logger->notice('Services:');
  $logger->notice( q{-} x $line_length );

  foreach my $mount ( sort keys %{ $runtime_config{service_registry} } ) {
    my $svc = $runtime_config{service_registry}->{$mount};
    $logger->notice( sprintf '  %-20s -> %s', $mount, ref $svc );
  }

  if ( keys %{ $runtime_config{error_document} } ) {
    $logger->notice( q{-} x $line_length );
    $logger->notice('Error Documents:');
    $logger->notice( q{-} x $line_length );
    foreach my $code ( sort keys %{ $runtime_config{error_document} } ) {
      $logger->notice( sprintf '  %-5s -> %s', $code, $runtime_config{error_document}->{$code} );
    }
  }

  $logger->notice( q{-} x $line_length );
  $logger->notice('MIME Types:');
  $logger->notice( q{-} x $line_length );
  foreach my $type ( sort keys %{ $runtime_config{mime_types} } ) {
    $logger->notice( sprintf '  %-5s -> %s', $type, $runtime_config{mime_types}->{$type} );
  }

  if ( keys %{ $runtime_config{aliases} } ) {
    $logger->notice( q{-} x $line_length );
    $logger->notice('Static Asset Aliases:');
    $logger->notice( q{-} x $line_length );

    foreach my $alias ( sort keys %{ $runtime_config{aliases} } ) {
      $logger->notice( sprintf '  %-20s -> %s', $alias, $runtime_config{aliases}->{$alias} );
    }
  }

  if ( keys %merged_routes ) {
    $logger->notice( q{-} x $line_length );
    $logger->notice('Routes:');
    $logger->notice( q{-} x $line_length );

    foreach my $mount ( sort keys %merged_routes ) {
      my $routes = $merged_routes{$mount};

      if ( is_array($routes) ) {
        foreach my $r ( @{$routes} ) {
          $logger->notice( sprintf '  %-20s %s -> %s', $mount, $r->{pattern} // '?', $r->{template} // '?' );
        }
      }
      elsif ( is_hash($routes) ) {
        foreach my $pattern ( keys %{$routes} ) {
          $logger->notice( sprintf '  %-20s %s -> %s', $mount, $pattern, $routes->{$pattern} );
        }
      }
    }
  }

  if ( $runtime_config{parse_templates} ) {
    $logger->notice( q{-} x $line_length );
    $logger->notice( sprintf '* Bedrock template parsing ENABLED for (%s) files.',
      join ', ', keys %{ $runtime_config{template_extensions} } );
  }

  $logger->notice( q{=} x $line_length );

  # Instantiate with runtime_config
  $runtime_config{port} = $port;

  my $server = Bedrock::MiniServer->new($port);
  $server->bedrock_server_config( \%runtime_config );

  $server->run();

  return 0;
}

########################################################################
sub _resolve_paths {
########################################################################
  my ($path_map) = @_;

  foreach my $p ( values %{$path_map} ) {
    next if $p !~ /[@]dist_dir[@]/xsm;
    $p =~ s/[@]dist_dir[@]/$BEDROCK_DIST_DIR/xsm;
  }

  return;
}

########################################################################
sub _mount_service {
########################################################################
  my ( $self, $runtime_config, $mount, $class, $config ) = @_;

  if ( $class !~ /\ABedrock::Service/xsm ) {
    $class = "Bedrock::Service::$class";
  }

  eval {
    load $class;

    my $instance = $class->new(
      service_config => $config,
      server_config  => {
        map { $_ => $runtime_config->{$_} }
          qw(aliases routes env log_level parse_templates
          template_extensions mime_types error_document
          directory_index port)
      },
      start_time => time,
    );

    $runtime_config->{service_registry}->{$mount} = $instance;
  };

  croak "Failed to mount $class at $mount: $EVAL_ERROR"
    if $EVAL_ERROR;

  return;
}

########################################################################
sub init {
########################################################################
  my ($self) = @_;

  $self->set_dist_dir($BEDROCK_DIST_DIR);

  my $config_file = $self->get_config;

  if ($config_file) {
    my @paths = grep {defined} ( $EMPTY, $ENV{BEDROCK_CONFIG_PATH}, $ENV{CONFIG_PATH}, "$BEDROCK_DIST_DIR/config" );

    foreach my $p (@paths) {
      if ( $p && $p !~ m{\z/}xsm ) {
        $p = "$p/";
      }

      next if !-r "$p$config_file";

      $config_file = "$p$config_file";
      last;
    }
  }

  $self->_init_server_config($config_file);

  return;
}

########################################################################
sub _init_server_config {
########################################################################
  my ( $self, $config_file ) = @_;

  if ( !$config_file && -e 'bedrock-miniserver.yml' ) {
    $config_file = 'bedrock-miniserver.yml';
  }

  my $has_config = $config_file;

  if ( !$config_file ) {
    $config_file = sprintf '%s/config/bedrock-miniserver.yml', $BEDROCK_DIST_DIR;
    $self->get_logger->warn( sprintf 'WARNING: attempting to use default miniserver configuration: %s', $config_file );
  }

  die "ERROR: Configuration file not found: $config_file"
    if $has_config && !-r $config_file;

  my $config = slurp_file($config_file);

  while ( $config =~ s/[@]dist_dir[@]/$BEDROCK_DIST_DIR/xsmg ) { }

  open my $fh, '<', \$config
    or croak "ERROR: could not open handle on scalar\n";

  my $conf = load_config( $fh, 1 );

  if ( my $log_level = $self->get_log_level ) {
    $conf->{log_level} = $log_level;
  }

  close $fh;

  if ( !$has_config ) {
    my ($document_root) = $self->get_args;
    $document_root //= 'html/';

    make_path( $document_root, qw(config config.d/plugin config.d/startup pebbles include session) );

    die "ERROR: no such directory $document_root\n"
      if !-d $document_root;

    if ( !-e "$document_root/index.roc" || !-e "$document_root/index.html" ) {
      open my $fh, '>', "$document_root/index.roc"
        or die "ERROR: could not open $document_root/index.roc for writing\n";

      print {$fh} q{<null $header.location("/bedrock-server-status")>};
      close $fh;
    }

    $conf->{aliases} //= {};
    $conf->{aliases}->{q{/}}            = $document_root;
    $conf->{directory_index}            = { q{/} => [qw(index.roc index.html)] };
    $conf->{env}->{BEDROCK_CONFIG_PATH} = sprintf '%s/config', Cwd::getcwd;

    DumpFile( 'bedrock-miniserver.yml', $conf );

    # create a reference tagx.xml
    my $tagx_file = sprintf '%s/config/tagx.xml', $BEDROCK_DIST_DIR;
    my $tagx      = load_config($tagx_file);
    @{$tagx}{qw(PEBBLE_DIR SESSION_DIR INCLUDE_DIR)} = qw(./pebbles ./session ./include);
    $tagx->{REPLACE_CONFIG}    = 'yes';
    $tagx->{ALLOW_SNIPPET_TAG} = 'yes';

    writeXML( $tagx, 'config/tagx.xml' );

    warn "Configuration file 'bedrock-miniserver.yml' created.\n";
  }

  # validate the configuration against our schema
  $self->validate_config($conf);

  $conf->{_source} = $config_file;

  $self->set_server_config($conf);

  return $conf;
}

########################################################################
sub validate_config {
########################################################################
  my ( $self, $conf ) = @_;

  # Path to the schema file defined above
  my $schema_path = "$BEDROCK_DIST_DIR/config/miniserver-schema.json";

  return $TRUE
    if !-e $schema_path || !$self->get_strict;

  my $schema = slurp_json($schema_path);

  my $v  = JSON::Schema::Validate->new($schema);
  my $ok = $v->validate($conf);

  if ( !$ok ) {
    my $err = $v->error;
    croak sprintf "ERROR: CONFIGURATION ERROR at %s: %s\n", $err->{path}, $err->{message};
  }

  return $TRUE;
}

########################################################################
package main;
########################################################################

use strict;
use warnings;

use Data::Dumper;
use English qw(-no_match_vars);
use YAML::XS;

my $defaults = eval {
  local $RS = undef;
  my $data = <DATA>;
  $data =~ s/^=pod.*\z//xsm;

  return Load($data);
};

exit Bedrock::MiniServer::CLI->main($defaults);

__END__

---
mime_types: 
  css:  text/css
  js:   application/javascript
  png:  image/png
  jpg:  image/jpeg
  gif:  image/gif
  html: text/html
  roc:  text/html
  jroc: application/json
  ico:  image/x-icon

aliases:
  /bedrock/img: '@dist_dir@/img'
  /bedrock/css: '@dist_dir@/css'
  /bedrock/javascript: '@dist_dir@/css'

=pod

=head1 NAME

bedrock-miniserver.pl - Bedrock development server

=head1 SYNOPSIS

 # Start a new application (zero-config quick start)
 bedrock-miniserver.pl

 # Start with a specific config
 bedrock-miniserver.pl -c app.yml

 # Start on a specific port
 bedrock-miniserver.pl -p 80

=head1 QUICK START

=head2 Start a New Application

 bedrock-miniserver.pl

Running the miniserver with no arguments and no existing
configuration file scaffolds a complete Bedrock application
directory. The following structure is created in the current
working directory:

 ./bedrock-miniserver.yml    # server configuration
 ./html/                     # document root
 ./html/index.roc            # default index (redirects to status page)
 ./config/                   # Bedrock configuration
 ./config/tagx.xml           # application config (seeded from distribution)
 ./config.d/                 # additional config overlays
 ./config.d/plugin/          # application plugin configs
 ./config.d/startup/         # startup module configs
 ./pebbles/                  # Bedrock pebble templates
 ./include/                  # include files
 ./session/                  # session file storage

The generated F<tagx.xml> is a copy of the distribution's reference
configuration with paths adjusted for local development
(C<PEBBLE_DIR>, C<SESSION_DIR>, C<INCLUDE_DIR> set to the relative
directories above). C<REPLACE_CONFIG> is set to C<yes> so the local
config stands alone, and C<ALLOW_SNIPPET_TAG> is enabled for
development convenience.

The generated F<bedrock-miniserver.yml> sets C<BEDROCK_CONFIG_PATH>
in the C<env:> block, pointing at the local F<config/> directory.
This ensures the miniserver loads your application's Bedrock
configuration on startup.

The server listens on port 8080 by default. Visit
C<http://localhost:8080/> in your browser to see the server status
page.

To start building your application, edit or replace
F<html/index.roc> and add templates to F<html/>. Add plugin
configurations to F<config.d/plugin/> as your application grows.

=head2 Testing a New Service

You've scaffolded a Bedrock service and want to test it locally.
Here's the minimal configuration to get running.

Save this as C<miniserver.yml>:

 port: 8080

 services:
   /api: Bedrock::Service::ProductCatalog

 aliases:
   /: ./htdocs/

Run it:

 bedrock-miniserver.pl --config miniserver.yml

Your service is now live at C<http://localhost:8080/api/>.

To serve Bedrock templates alongside your service, enable the
template accelerator:

 port: 8080
 parse_templates: yes

 services:
   /api: Bedrock::Service::ProductCatalog

 aliases:
   /: ./htdocs/

Now C<.roc> files under F<./htdocs/> are parsed as Bedrock templates,
and C</api> routes hit your service.

To verify your service routes match what you expect:

 bedrock-service.cgi --service product-catalog routes

See L</CONFIGURATION> below for the full set of options.

=head1 DESCRIPTION

This script provides a standalone HTTP server for Bedrock
applications, built on top of C<HTTP::Server::Simple::CGI>. It serves
three roles:

=over 4

=item 1. B<Application Server>: Hosts multiple Bedrock Services
mounted at configurable URL prefixes, with full route translation
and rewriting.

=item 2. B<Template Accelerator>: Serves and parses static Bedrock
templates (F<.roc>, F<.jroc>) with the full Bedrock runtime
environment.

=item 3. B<Static File Server>: Serves raw assets (Images, CSS, JS)
from aliased directories.

=back

=head1 OPTIONS

=over 4

=item B<--config | -c>

Path to the YAML configuration file. If not specified, the server
looks for F<bedrock-miniserver.yml> in the current directory. If
that is not found, it scaffolds a new application directory.

=item B<--service | -s>

Perl class name of a single service to mount (quick-start mode).

=item B<--mount-point | -m>

URL prefix for a service specified via C<--service> (default: /).

=item B<--port | -p>

TCP port to listen on (default: 8080).

=item B<--strict | --no-strict>

Enable or disable strict schema validation of the configuration
file. Enabled by default. Use C<--no-strict> to bypass validation
(miniserver-schema.json) before startup. Use C<--no-strict> to bypass
validation at your own risk.

=item B<--log-level | -l>

Server log verbosity: debug, info, warn, error, fatal.
Overrides the C<log_level> setting in the YAML config.

=back

=head1 BEDROCK CONFIGURATION

At startup, the miniserver loads the fully merged Bedrock
configuration using the same pipeline as C<Apache::Bedrock>. This
means:

=over 4

=item * F<tagx.xml> is located via C<BEDROCK_CONFIG_PATH>

=item * Multiple F<tagx.xml> files along the config path are merged

=item * Plugin configs in F<config.d/plugin/> are discovered and
merged into the C<MODULES> array

=item * Startup module configs in F<config.d/startup/> are likewise
merged

=item * Data sources from F<data-sources.xml> files are registered

=back

The resulting config object is cached for the life of the server
process and used for every template request. This is the same config
object that would be available via C<$config> in your templates under
Apache.

The miniserver's YAML C<overrides:> block is applied on top of the
merged Bedrock config at startup, allowing you to override specific
values (such as C<BEDROCK_IMAGE_URL> or C<ABSOLUTE_PATHS>) without
editing your F<tagx.xml>.

If the Bedrock config cannot be loaded (missing F<tagx.xml>, invalid
paths), the miniserver falls back to a bare C<Bedrock::Config>
object and logs a warning.

=head2 Configuration Tree Layout

The standard Bedrock configuration tree that the miniserver expects
mirrors the production layout used with Apache:

 config/
 config/tagx.xml              # main Bedrock config
 config.d/
 config.d/startup/            # system startup modules (e.g., session)
 config.d/plugin/             # application plugins (BLMs)

Plugin configuration files in F<config.d/plugin/> must define at
least a C<module> and C<binding> key. They are automatically merged
into the config's C<MODULES> array at startup.

This layout is created for you by the zero-config quick start. If
you are adapting an existing application, point
C<BEDROCK_CONFIG_PATH> at your existing config tree (or symlink it
locally) and the miniserver will load it as-is.

=head1 BEDROCK TEMPLATE PARSING

In addition to hosting Services, the Miniserver acts as a "Smart
Static Server."

When a request matches a file with a Bedrock extension (configured via
C<template_extensions>, typically F<.roc>), the server does B<not>
serve the raw source code. Instead, it:

=over 4

=item 1. B<Instantiates the Bedrock Stack>: The fully merged Bedrock
config (loaded at startup) provides the C<MODULES> array. The
miniserver instantiates the core startup objects that Bedrock pages
expect:

=over 8

=item * C<$bedrock> (Utilities)

=item * C<$config> (Configuration)

=item * C<$cookie> (Cookie access)

=item * C<$env> (Environment variables)

=item * C<$header> (HTTP Header control)

=item * C<$input> (CGI Parameters)

=back

Any additional modules defined in your F<tagx.xml> or
F<config.d/plugin/> are available in the config object. Application
plugins (BLMs) that are declared in your C<MODULES> array can be
used in templates via the C<E<lt>pluginE<gt>> tag.

=item 2. B<Enables Sessions>: If a session manager is configured in
the miniserver YAML (via the C<session:> block), it is initialized
for each request.

A simple session manager to use for development is the SQLite
manager. You can install the C<BLM::Startup::SQLiteSession> plugin
from the Bedrock CPAN repository.

L<http://cpan.openbedrock.net>

You'll find a SQL script you can use to create your database and
session table in the plugin's distribution directory.

 perl -MFile::ShareDir=dist_file \
   -e 'print dist_file("BLM-Startup-SQLiteSession", "create-session-table.sql");'

 session:
   enabled: yes
   binding: session
   session: yes
   module: BLM::Startup::SQLiteSession
   config:
     data_source: dbi:SQLite:dbname=bedrock.db
     table_name: session
     expiry_secs: 900
     param: session
     log_level: info

=item 3. B<Parses the Template>: It renders the page using
C<Bedrock::Template>.

=item 4. B<Handles Errors>: If parsing fails, it generates a detailed
HTML error report with code highlighting, similar to the full
Apache::Bedrock handler.

=back

B<Usage:>

Simply define an alias pointing to your document root. Any F<.roc>
file accessed via that alias will be parsed automatically.

  # In bedrock-miniserver.yml
  aliases:
    /birds: ./htdocs/birds

  # Accessing http://localhost:8080/birds/index.roc now renders the template!

While F<.roc> is the standard extension, the list of extensions that
trigger the accelerator is fully configurable via C<template_extensions>
in the YAML. This allows for specialized templates, such as F<.jroc> for
dynamic JSON generation.

=head1 ARCHITECTURE

=head2 Request Pipeline

The server processes each incoming request through a series of
resolution stages. The first stage to match handles the request:

=over 4

=item 1. B<Exact Service Match>: If the request path exactly matches
a mounted service (with or without trailing slash), the service
handles the request immediately.

=item 2. B<Directory Index>: If the request matches a
C<directory_index> prefix, the server tries each candidate file in
order and serves the first readable one.

=item 3. B<Alias Resolution>: The server checks if the request
matches a configured C<alias> and the target file exists on disk.
If the file has a Bedrock template extension, it is parsed. Otherwise
it is served as a static asset.

=item 4. B<Template Route Matching>: The server checks the C<routes>
configuration (merged from both Bedrock config and miniserver YAML)
using C<Bedrock::Router>. If a route matches, the target template is
resolved relative to C<PEBBLE_DIR> and rendered.

=item 5. B<Service Prefix Match>: The server checks if the request
path starts with a mounted service prefix (longest prefix wins) and
dispatches to that service.

=item 6. B<404 Not Found>: If none of the above match, the server
returns a 404 response.

=back

This layered approach allows you to mount a Service at C</> while
still serving static assets from an alias like C</css>, or to have
specific static files "overlay" a dynamic application.

=head2 The Service Registry

The server maintains a registry of mounted services using "Longest
Prefix Match" routing.

  /       -> Bedrock::Service::RootApp
  /birds  -> Bedrock::Service::Autocomplete

After all services are mounted, the registry is finalized and each
service receives a copy mapping mount points to class names (via the
C<registry> accessor on C<Bedrock::Service>).

=head2 Route Translation

When a request matches a service, the server B<translates> the path by
stripping the mount prefix before invoking the service. This allows
services to be written without knowledge of where they are mounted.

=head2 Advanced Routing (Regex Rewrites)

In addition to simple prefix stripping, the server supports complex
URL remapping via the C<routes> configuration block. This allows
mapping RESTful URLs to internal service paths using named captures
and variable substitution.

Example (miniserver YAML):

  routes:
    /api:
      '^/user/(:id)$': '/user/view?id=$1'

In this example, a request to C</api/user/123> is translated to
C</user/view?id=123> before being handed to the service.

=head2 Template Routes (Bedrock Config)

Routes defined in your Bedrock configuration (typically
F<routes.xml>) are also supported. These use C<Bedrock::Router>
pattern syntax with named parameters and wildcards:

 <object name="routes">
   <array>
     <object>
       <scalar name="pattern">/user/:id</scalar>
       <scalar name="template">user_profile.roc</scalar>
     </object>
     <object>
       <scalar name="pattern">/docs/*path</scalar>
       <scalar name="template">markdown.roc</scalar>
     </object>
   </array>
 </object>

Bedrock config routes are loaded at startup and merged under the
root (C</>) mount point. Miniserver YAML routes take precedence on
a per-mount-point basis -- if both define routes for C</api>, the
YAML version wins.

Captured parameters are available in templates via C<$input>:

 # Route: /user/:id
 # URL: /user/123
 <var $input.id>  <!-- prints: 123 -->

See L<Bedrock::Router> for complete pattern syntax.

=head2 Environment Virtualization

To ensure that Services and Templates are portable, the Miniserver
manages the environment for each request. It manually calculates and
overrides C<SCRIPT_NAME> and C<PATH_INFO> based on the mount point
or alias, allowing code to operate correctly regardless of its
location in the public URL space.

=head1 CONFIGURATION

The server configuration is driven by a YAML file (e.g.,
F<bedrock-miniserver.yml>).

  port: 8080

  # Control server verbosity (debug, info, warn, error, fatal)
  # Default: info
  log_level: debug

  # 1. Environment Injection
  #    These variables are injected into %ENV at startup.
  #    BEDROCK_CONFIG_PATH tells the miniserver where to find
  #    your Bedrock configuration tree (tagx.xml, config.d/, etc.)
  env:
    BEDROCK_CONFIG_PATH: ./config
    DBI_TRACE: 1
    MY_API_KEY: "secret"

  # 2. Services
  services:
    /api: MyApp::Service::API
    /:    MyApp::Service::Root

  # 3. Aliases
  aliases:
    /css: ./htdocs/css/
    /:    ./htdocs/root/

  # 4. Directory Indices
  #    Define which file(s) to serve when a directory is requested.
  #    If multiple files are listed, they are tried in order.
  directory_index:
    /bedrock:
      - index.html
      - index.roc

  # 5. Advanced Routing (Regex Rewrites)
  #    Map complex URLs to internal paths before they hit the Service.
  #    Use (:name) to capture segments.
  routes:
    /api:
      # Maps /api/user/123 -> /user/view?id=123
      '^/user/(:id)$': '/user/view?id=$1'

  # 6. Bedrock template configuration
  parse_templates: yes
  template_extensions:
    - roc
    - jroc

  # 7. Session Manager (Used by both Services and Accelerator)
  session:
    module: BLM::Startup::MemorySession
    config:
      persistence_enabled: yes

  # 8. Overrides
  #    Values here are applied on top of the merged Bedrock config
  #    (tagx.xml) at startup.
  overrides:
    ALLOW_SNIPPET_TAG: yes

=over 4

=item port:

The TCP port on which the server will listen (default: 8080).

=item env:

A hash of variables to be injected into the system environment
(C<%ENV>) at startup. C<BEDROCK_CONFIG_PATH> is particularly
important -- it tells the miniserver where to find your Bedrock
configuration tree. If not set, the miniserver falls back to the
distribution's default config.

=item services:

A hash mapping URL prefixes to Perl class names. Each class must
be a subclass of C<Bedrock::Service>.

=item aliases:

A hash mapping URI prefixes to physical filesystem paths for static
asset or template serving.

The miniserver will provide these additional aliases automatically:

 aliases:
   /bedrock/img: '@dist_dir@/img'
   /bedrock/css: '@dist_dir@/css'
   /bedrock/javascript: '@dist_dir@/css'

B<Trailing Slashes in Aliases>

When aliasing a directory (e.g., mapping C</> to C<html>), a trailing
slash must be included in both the path and the target (C</: html/>).
Without the slash, the translation logic performs a literal
string substitution, which may result in incorrect filenames (e.g.,
C</foo.roc> becoming C<htmlfoo.roc>). This behavior is intentional as
it allows for prefix-based filename remapping.

=item directory_index:

A hash mapping directory paths to an ordered list of candidate files
to serve when that directory is requested. Resolution happens at
request time, before alias resolution.

 directory_index:
   /release-notes:
     - index.roc

=item routes:

A hash of URI-to-resource mappings or regex rewrite rules for complex
URL remapping. Routes defined here are merged with any routes found
in your Bedrock configuration (F<routes.xml>). Bedrock config routes
serve as the baseline under the root (C</>) mount; miniserver YAML
routes take precedence on a per-mount-point basis.

=item parse_templates:

Boolean flag to enable the Bedrock Template Accelerator for files
matching C<template_extensions>.

=item template_extensions:

An array of file extensions that trigger Bedrock template parsing
(default: roc, rock, jroc, jrock).

I<Note: .rock and .jrock extensions are typically used in the Apache
environment to specifically request that these files be handled by
C<mod_cgi> rather than C<mod_perl>.>

=item mime_types:

A mapping of file extensions to Content-Type headers required for
correctly serving static assets. A default list of mime types is
provided for you.

 mime_types:
   css:  text/css
   js:   application/javascript
   png:  image/png
   jpg:  image/jpeg
   gif:  image/gif
   html: text/html
   roc:  text/html
   jroc: application/json
   ico:  image/x-icon

=item error_document:

A mapping of HTTP status codes to custom error page locations.

 error_document:
   404: html/error.roc
   400: html/bad-request.roc
   403: html/forbidden.roc

=item mount_point:

The URL prefix used when a service is specified via the CLI
(default: /).

=item session:

Configures the session manager module and its parameters for use
by templates and services.

B<Example:>

 session:
   enabled: true
   binding: session
   session: yes
   module: BLM::Startup::MemorySession
   config:
     table_name: session
     expiry_secs: 900
     param: session
     log_level: info
     persistence_enable: no

=item overrides:

A hash of Bedrock-specific configuration values that are applied on
top of the merged F<tagx.xml> config at startup. Use this to override
individual settings without modifying your configuration tree.

=item log_level:

The verbosity level for the server logs (debug, info, warn,
error, fatal).

=back

=head1 CONFIGURATION VALIDATION

As of version 3.7.5, the Miniserver performs strict validation of its
configuration file using B<JSON Schema>. This prevents misconfigurations
from being interpreted as runtime server bugs.

The server looks for the schema definition at:
C<@dist_dir@/config/miniserver-schema.json>.

If the configuration contains unknown keys or invalid data types (e.g.,
providing a string where an array is expected for C<directory_index>),
the server will refuse to start and provide a specific path to the
error within the YAML file.

I<You can override this check using the C<--no-strict> option...although caveat emptor.>

=head1 ROUTE RESOLUTION

The MiniServer employs a specific precedence logic when resolving
incoming requests:

=over 4

=item 1. Exact Service Match

If the request path exactly matches a mounted service (with or
without trailing slash), the service handles the request immediately.
No further resolution is attempted.

=item 2. Directory Index

If the request matches a C<directory_index> prefix, the server
resolves the filesystem base via aliases and tries each candidate
file in order. The first readable file is served.

=item 3. Alias Resolution

The server checks whether the request path matches a configured
alias. If the target file exists, it is served (parsed as a template
if its extension matches C<template_extensions>, or served raw
otherwise). If the target does not exist on disk, the request falls
through.

=item 4. Template Route Matching

The merged C<routes> (from both Bedrock config and miniserver YAML)
are checked using C<Bedrock::Router>. If a route matches, the
target template is resolved relative to C<PEBBLE_DIR> and rendered.

=item 5. Service Prefix Match

The server checks if the request path starts with a mounted service
prefix (longest prefix wins). Route translation and regex rewrites
are applied before the service handles the request.

=item 6. Not Found

If none of the above match, a 404 response is returned. If an
C<error_document> is configured for 404, that page is served instead.

=back

=head1 MIGRATION TO PRODUCTION

The miniserver is designed as a development environment that mirrors
the production deployment model. The scaffolded directory layout and
configuration files are structured to transfer directly to an Apache
deployment:

=over 4

=item * F<config/tagx.xml> and F<config.d/> move to your Apache
site's config directory. Update absolute paths as needed.

=item * Services defined in the miniserver YAML are deployed as
C<LocationMatch> blocks with C<PerlResponseHandler> directives. Use
C<bedrock-service.cgi --service MyService install> to generate the
Apache configuration.

=item * Route rewrites from the miniserver YAML become
C<RewriteRule> directives in your Apache configuration.

=item * Template routes from F<routes.xml> work identically under
both the miniserver and C<Apache::Bedrock>.

=item * Aliases become Apache C<Alias> directives.

=back

=head1 EXIT STATUS

Returns 0 on successful execution. Returns non-zero if a service class
fails to load or the configuration is invalid.

